#include <iostream>
using namespace std;

int main() {
    int arr[] = {1,2,3,4};
    int n = 4;
    int dp[10][10] = {0};

    for(int len=2; len<n; len++) {
        for(int i=1; i<n-len+1; i++) {
            int j = i + len - 1;
            dp[i][j] = 1e9;

            for(int k=i; k<j; k++) {
                dp[i][j] = min(dp[i][j],
                    dp[i][k] + dp[k+1][j] + arr[i-1]*arr[k]*arr[j]);
            }
        }
    }

    cout << dp[1][n-1];
}
#include <iostream>
using namespace std;

int main() {
    string s = "bbab";
    int n = s.length();
    int dp[10][10];

    for(int i=0;i<n;i++) dp[i][i]=1;

    for(int len=2;len<=n;len++) {
        for(int i=0;i<n-len+1;i++) {
            int j = i+len-1;
            if(s[i]==s[j])
                dp[i][j]=2+dp[i+1][j-1];
            else
                dp[i][j]=max(dp[i+1][j], dp[i][j-1]);
        }
    }

    cout << dp[0][n-1];
}
#include <iostream>
using namespace std;

int main() {
    int grid[2][2] = {{1,3},{1,5}};
    int dp[2][2];

    dp[0][0] = grid[0][0];

    for(int i=1;i<2;i++)
        dp[i][0] = dp[i-1][0] + grid[i][0];

    for(int j=1;j<2;j++)
        dp[0][j] = dp[0][j-1] + grid[0][j];

    for(int i=1;i<2;i++) {
        for(int j=1;j<2;j++) {
            dp[i][j] = min(dp[i-1][j], dp[i][j-1]) + grid[i][j];
        }
    }

    cout << dp[1][1];
}