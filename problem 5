int main() {
    int grid[2][2] = {{1,3},{1,5}};
    int dp[2][2];

    dp[0][0] = grid[0][0];

    for(int i=1;i<2;i++)
        dp[i][0] = dp[i-1][0] + grid[i][0];

    for(int j=1;j<2;j++)
        dp[0][j] = dp[0][j-1] + grid[0][j];

    for(int i=1;i<2;i++) {
        for(int j=1;j<2;j++) {
            dp[i][j] = min(dp[i-1][j], dp[i][j-1]) + grid[i][j];
        }
    }

    cout << dp[1][1];
}
