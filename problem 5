struct Node {
    int data;
    Node* next;
};

int main() {
    Node* head = new Node{1,NULL};
    head->next = new Node{2,NULL};
    head->next->next = head; // cycle

    Node *slow=head, *fast=head;

    while(fast && fast->next) {
        slow = slow->next;
        fast = fast->next->next;

        if(slow == fast) {
            cout << "Cycle Detected";
            break;
        }
    }
}