int main() {
    string s = "bbab";
    int n = s.length();
    int dp[10][10];

    for(int i=0;i<n;i++) dp[i][i]=1;

    for(int len=2;len<=n;len++) {
        for(int i=0;i<n-len+1;i++) {
            int j = i+len-1;
            if(s[i]==s[j])
                dp[i][j]=2+dp[i+1][j-1];
            else
                dp[i][j]=max(dp[i+1][j], dp[i][j-1]);
        }
    }

    cout << dp[0][n-1];
}
