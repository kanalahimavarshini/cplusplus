using namespace std;

int main() {
    int binary = 1010, decimal = 0, i = 0;

    while(binary > 0) {
        int rem = binary % 10;
        decimal += rem * pow(2, i);
        binary /= 10;
        i++;
    }

    cout << decimal;
}
#include <iostream>
using namespace std;

int fact(int n) {
    int f = 1;
    for(int i = 1; i <= n; i++)
        f *= i;
    return f;
}

int main() {
    int n = 145, sum = 0, temp = n;

    while(n > 0) {
        sum += fact(n % 10);
        n /= 10;
    }

    if(sum == temp)
        cout << "Strong Number";
    else
        cout << "Not Strong";
}
