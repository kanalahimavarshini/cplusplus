#include <iostream>
using namespace std;

int main() {
    int n = 20;

    for(int i = 2; i <= n; i++) {
        bool isPrime = true;

        for(int j = 2; j <= i/2; j++) {
            if(i % j == 0) {
                isPrime = false;
                break;
            }
        }

        if(isPrime)
            cout << i << " ";
    }
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {1, 2, 2, 3, 1};
    int n = 5;

    for(int i = 0; i < n; i++) {
        int count = 1;

        if(arr[i] == -1) continue;

        for(int j = i + 1; j < n; j++) {
            if(arr[i] == arr[j]) {
                count++;
                arr[j] = -1;
            }
        }

        cout << arr[i] << " occurs " << count << " times\n";
    }
}