#include <iostream>
using namespace std;

int main() {
    int a = 12, b = 18;

    while(b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }

    cout << "GCD: " << a;
}
#include <iostream>
using namespace std;

int main() {
    int a = 12, b = 18, lcm;

    int max = (a > b) ? a : b;

    while(true) {
        if(max % a == 0 && max % b == 0) {
            lcm = max;
            break;
        }
        max++;
    }

    cout << "LCM: " << lcm;
}
#include <iostream>
using namespace std;

int main() {
    int n = 12345, count = 0;

    while(n != 0) {
        count++;
        n /= 10;
    }

    cout << "Digits: " << count;
}
#include <iostream>
using namespace std;

int main() {
    int n = 123, sum = 0;

    while(n != 0) {
        sum += n % 10;
        n /= 10;
    }

    cout << "Sum: " << sum;
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {10, 25, 5, 30};
    int max = arr[0];

    for(int i = 1; i < 4; i++) {
        if(arr[i] > max)
            max = arr[i];
    }

    cout << "Largest: " << max;
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {10, 20, 30, 40};
    int first = 0, second = 0;

    for(int i = 0; i < 4; i++) {
        if(arr[i] > first) {
            second = first;
            first = arr[i];
        }
        else if(arr[i] > second && arr[i] != first) {
            second = arr[i];
        }
    }

    cout << "Second Largest: " << second;
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {1, 2, 3, 4};
    int n = 4;

    for(int i = 0; i < n/2; i++) {
        swap(arr[i], arr[n-i-1]);
    }

    for(int i = 0; i < n; i++)
        cout << arr[i] << " ";
}