#include <iostream>
using namespace std;

int main() {
    int a = 12, b = 18;

    while(b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }

    cout << "GCD: " << a;
}
#include <iostream>
using namespace std;

int main() {
    int a = 12, b = 18, lcm;

    int max = (a > b) ? a : b;

    while(true) {
        if(max % a == 0 && max % b == 0) {
            lcm = max;
            break;
        }
        max++;
    }

    cout << "LCM: " << lcm;
}
