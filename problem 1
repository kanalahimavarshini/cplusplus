#include <iostream>
using namespace std;

int main() {
    int arr[] = {10, 20, 30, 40};
    int first = 0, second = 0;

    for(int i = 0; i < 4; i++) {
        if(arr[i] > first) {
            second = first;
            first = arr[i];
        }
        else if(arr[i] > second && arr[i] != first) {
            second = arr[i];
        }
    }

    cout << "Second Largest: " << second;
}
