using namespace std;

int main() {
    int V = 3;
    vector<pair<int,int>> adj[3];

    adj[0].push_back({1,4});
    adj[1].push_back({0,4});
    adj[1].push_back({2,2});
    adj[2].push_back({1,2});

    vector<int> key(V, 1e9);
    vector<bool> inMST(V, false);

    priority_queue<pair<int,int>, vector<pair<int,int>>, greater<pair<int,int>>> pq;

    key[0] = 0;
    pq.push({0,0});

    int cost = 0;

    while(!pq.empty()) {
        int u = pq.top().second;
        pq.pop();

        if(inMST[u]) continue;
        inMST[u] = true;
        cost += key[u];

        for(auto it : adj[u]) {
            int v = it.first, w = it.second;
            if(!inMST[v] && w < key[v]) {
                key[v] = w;
                pq.push({key[v], v});
            }
        }
    }

    cout << "MST cost: " << cost;
}
