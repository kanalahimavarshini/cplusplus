struct Trie {
    Trie* child[26];
    bool end;
};

Trie* create() {
    Trie* node = new Trie();
    node->end = false;
    for(int i=0;i<26;i++) node->child[i]=NULL;
    return node;
}

void insert(Trie* root, string s) {
    for(char c : s) {
        int i = c - 'a';
        if(!root->child[i]) root->child[i] = create();
        root = root->child[i];
    }
    root->end = true;
}

bool search(Trie* root, string s) {
    for(char c : s) {
        int i = c - 'a';
        if(!root->child[i]) return false;
        root = root->child[i];
    }
    return root->end;
}

int main() {
    Trie* root = create();
    insert(root,"cat");
    cout << search(root,"cat");
}
