void dfs(char g[][3], int i, int j) {
    if(i<0||j<0||i>=3||j>=3||g[i][j]=='0') return;

    g[i][j]='0';

    dfs(g,i+1,j);
    dfs(g,i-1,j);
    dfs(g,i,j+1);
    dfs(g,i,j-1);
}

