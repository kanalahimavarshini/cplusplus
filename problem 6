
#include <iostream>
#include <queue>
using namespace std;

int main() {
    priority_queue<int> maxH;
    priority_queue<int, vector<int>, greater<int>> minH;

    int arr[] = {5,15,1,3};

    for(int x : arr) {
        if(maxH.empty() || x <= maxH.top())
            maxH.push(x);
        else
            minH.push(x);

        if(maxH.size() > minH.size()+1) {
            minH.push(maxH.top());
            maxH.pop();
        }
        else if(minH.size() > maxH.size()) {
            maxH.push(minH.top());
            minH.pop();
        }

        cout << maxH.top() << " ";
    }
}
#include <iostream>
using namespace std;

struct Trie {
    Trie* child[26];
    bool end;
};

Trie* create() {
    Trie* node = new Trie();
    node->end = false;
    for(int i=0;i<26;i++) node->child[i]=NULL;
    return node;
}

void insert(Trie* root, string s) {
    for(char c : s) {
        int i = c - 'a';
        if(!root->child[i]) root->child[i] = create();
        root = root->child[i];
    }
    root->end = true;
}

bool search(Trie* root, string s) {
    for(char c : s) {
        int i = c - 'a';
        if(!root->child[i]) return false;
        root = root->child[i];
    }
    return root->end;
}

int main() {
    Trie* root = create();
    insert(root,"cat");
    cout << search(root,"cat");
}