int main() {
    int grid[3][3] = {{0,1,0},{0,0,0},{1,0,0}};
    bool vis[3][3]={false};

    queue<pair<int,int>> q;
    q.push({0,0});
    vis[0][0]=true;

    int dx[]={1,-1,0,0}, dy[]={0,0,1,-1};

    while(!q.empty()) {
        auto [x,y]=q.front(); q.pop();

        if(x==2 && y==2) {
            cout<<"Reached";
            break;
        }

        for(int i=0;i<4;i++) {
            int nx=x+dx[i], ny=y+dy[i];
            if(nx>=0&&ny>=0&&nx<3&&ny<3 && !vis[nx][ny] && grid[nx][ny]==0) {
                vis[nx][ny]=true;
                q.push({nx,ny});
            }
        }
    }
}
