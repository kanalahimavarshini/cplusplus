    int n = 4, sum = 0;

    for(int x:arr) sum += x;
    if(sum % 2) return cout<<"No",0;

    sum /= 2;
    bool dp[10][50] = {false};

    for(int i=0;i<=n;i++) dp[i][0]=true;

    for(int i=1;i<=n;i++) {
        for(int j=1;j<=sum;j++) {
            if(arr[i-1]<=j)
                dp[i][j]=dp[i-1][j]||dp[i-1][j-arr[i-1]];
