void dfs(int u, int parent) {
    visited[u] = true;
    disc[u] = low[u] = ++timer;
    int children = 0;

    for(int v : adj[u]) {
        if(v == parent) continue;

        if(!visited[v]) {
            children++;
            dfs(v,u);
            low[u] = min(low[u], low[v]);

            if(parent != -1 && low[v] >= disc[u])
                ap[u] = true;
        } else {
            low[u] = min(low[u], disc[v]);
        }
    }

    if(parent == -1 && children > 1)
        ap[u] = true;
}

