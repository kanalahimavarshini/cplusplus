bool canPlace(int arr[], int n, int c, int dist) {
    int count=1,last=arr[0];

    for(int i=1;i<n;i++) {
        if(arr[i]-last>=dist) {
            count++;
            last=arr[i];
        }
    }
    return count>=c;
}

