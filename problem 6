
#include <iostream>
#include <queue>
using namespace std;

int main() {
    priority_queue<int> maxH;
    priority_queue<int, vector<int>, greater<int>> minH;

    int arr[] = {5,15,1,3};

    for(int x : arr) {
        if(maxH.empty() || x <= maxH.top())
            maxH.push(x);
        else
            minH.push(x);

        if(maxH.size() > minH.size()+1) {
            minH.push(maxH.top());
            maxH.pop();
        }
        else if(minH.size() > maxH.size()) {
            maxH.push(minH.top());
            minH.pop();
        }

        cout << maxH.top() << " ";
    }
}
#include <iostream>
using namespace std;

struct Trie {
    Trie* child[26];
    bool end;
};

Trie* create() {
    Trie* node = new Trie();
    node->end = false;
    for(int i=0;i<26;i++) node->child[i]=NULL;
    return node;
}

void insert(Trie* root, string s) {
    for(char c : s) {
        int i = c - 'a';
        if(!root->child[i]) root->child[i] = create();
        root = root->child[i];
    }
    root->end = true;
}

bool search(Trie* root, string s) {
    for(char c : s) {
        int i = c - 'a';
        if(!root->child[i]) return false;
        root = root->child[i];
    }
    return root->end;
}

int main() {
    Trie* root = create();
    insert(root,"cat");
    cout << search(root,"cat");
}
#include <iostream>
using namespace std;

bool dfs(char b[][3], int i, int j, string w, int k) {
    if(k == w.size()) return true;
    if(i<0||j<0||i>=3||j>=3||b[i][j]!=w[k]) return false;

    char temp = b[i][j];
    b[i][j] = '#';

    bool found = dfs(b,i+1,j,w,k+1) ||
                 dfs(b,i-1,j,w,k+1) ||
                 dfs(b,i,j+1,w,k+1) ||
                 dfs(b,i,j-1,w,k+1);

    b[i][j] = temp;
    return found;
}

int main() {
    char b[3][3] = {{'A','B','C'},{'D','E','F'},{'G','H','I'}};
    cout << dfs(b,0,0,"ABE",0);
}