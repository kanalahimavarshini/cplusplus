bool possible(int arr[], int n, int m, int maxPages) {
    int students=1,sum=0;

    for(int i=0;i<n;i++) {
        if(arr[i]>maxPages) return false;

        if(sum+arr[i]>maxPages) {
            students++;
            sum=arr[i];
        } else sum+=arr[i];
    }
    return students<=m;
}

