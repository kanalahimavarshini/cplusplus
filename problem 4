using namespace std;

vector<int> adj[10];
bool visited[10], rec[10];

bool dfs(int node) {
    visited[node] = true;
    rec[node] = true;

    for(int x : adj[node]) {
        if(!visited[x] && dfs(x)) return true;
        else if(rec[x]) return true;
    }

    rec[node] = false;
    return false;
}

int main() {
    adj[1].push_back(2);
    adj[2].push_back(1);

    if(dfs(1))
        cout << "Cycle";
    else
        cout << "No Cycle";
}
