int parent[10];

int find(int x) {
    if(parent[x] == x) return x;
    return parent[x] = find(parent[x]);
}

void unite(int a, int b) {
    a = find(a);
    b = find(b);
    if(a != b) parent[a] = b;
}

int main() {
    for(int i=0;i<10;i++) parent[i]=i;

    unite(1,2);
    unite(2,3);

    cout << find(3);
}
#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

struct Edge {
    int u,v,w;
};

bool cmp(Edge a, Edge b) {
    return a.w < b.w;
}

int parent[10];

int find(int x) {
    if(parent[x]==x) return x;
    return parent[x]=find(parent[x]);
}

int main() {
    vector<Edge> edges = {{0,1,4},{1,2,2},{0,2,5}};

    for(int i=0;i<10;i++) parent[i]=i;

    sort(edges.begin(), edges.end(), cmp);

    int cost = 0;

    for(auto e : edges) {
        if(find(e.u) != find(e.v)) {
            cost += e.w;
            parent[find(e.u)] = find(e.v);
        }
    }

    cout << "MST cost: " << cost;
}
