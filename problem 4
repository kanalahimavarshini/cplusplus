#include <iostream>
using namespace std;

int board[10];

bool safe(int row, int col) {
    for(int i = 0; i < row; i++) {
        if(board[i] == col || abs(board[i]-col) == row-i)
            return false;
    }
    return true;
}

void solve(int row, int n) {
    if(row == n) {
        for(int i = 0; i < n; i++)
            cout << board[i] << " ";
        cout << endl;
        return;
    }

    for(int col = 0; col < n; col++) {
        if(safe(row, col)) {
            board[row] = col;
            solve(row+1, n);
        }
    }
}

int main() {
    solve(0, 4);
}
