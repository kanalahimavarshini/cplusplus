int main() {
    int coins[] = {1,2,5};
    int sum = 5;
    int dp[10] = {0};

    dp[0] = 1;

    for(int i = 0; i < 3; i++) {
        for(int j = coins[i]; j <= sum; j++) {
            dp[j] += dp[j - coins[i]];
        }
    }

    cout << dp[sum];
}
#include <iostream>
#include <vector>
#include <queue>
using namespace std;

vector<pair<int,int>> adj[10];

int main() {
    priority_queue<pair<int,int>, vector<pair<int,int>>, greater<pair<int,int>>> pq;
    vector<int> dist(10, 1e9);

    adj[0].push_back({1,4});
    adj[0].push_back({2,1});
    adj[2].push_back({1,2});

    dist[0] = 0;
    pq.push({0,0});

    while(!pq.empty()) {
        int d = pq.top().first;
        int node = pq.top().second;
        pq.pop();

        for(auto it : adj[node]) {
            int next = it.first;
            int weight = it.second;

            if(d + weight < dist[next]) {
                dist[next] = d + weight;
                pq.push({dist[next], next});
            }
        }
    }

    cout << "Distance to 1: " << dist[1];
}
