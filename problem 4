    int sum = 9, n = 6;

    bool dp[10][50] = {false};

    for(int i = 0; i <= n; i++)
        dp[i][0] = true;

    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= sum; j++) {
            if(arr[i-1] <= j)
                dp[i][j] = dp[i-1][j] || dp[i-1][j-arr[i-1]];
            else
                dp[i][j] = dp[i-1][j];
        }
    }

    if(dp[n][sum])
        cout << "Yes";
    else
        cout << "No";
}
#include <iostream>
using namespace std;

int board[10];

bool safe(int row, int col) {
    for(int i = 0; i < row; i++) {
        if(board[i] == col || abs(board[i]-col) == row-i)
            return false;
    }
    return true;
}

void solve(int row, int n) {
    if(row == n) {
        for(int i = 0; i < n; i++)
            cout << board[i] << " ";
        cout << endl;
        return;
    }

    for(int col = 0; col < n; col++) {
        if(safe(row, col)) {
            board[row] = col;
            solve(row+1, n);
        }
    }
}

int main() {
    solve(0, 4);
}
