int main() {
    string s = "{[()]}";
    stack<char> st;

    for(char c : s) {
        if(c=='('||c=='{'||c=='[')
            st.push(c);
        else {
            if(st.empty()) return 0;
            st.pop();
        }
    }

    if(st.empty())
        cout << "Balanced";
    else
        cout << "Not Balanced";
}
