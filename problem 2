#include <iostream>
using namespace std;

int main() {
    int arr[] = {5, 2, 4, 6};
    int n = 4;

    for(int i = 1; i < n; i++) {
        int key = arr[i];
        int j = i - 1;

        while(j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = key;
    }

    for(int i = 0; i < n; i++)
        cout << arr[i] << " ";
}
#include <iostream>
#include <stack>
using namespace std;

int main() {
    string s = "{[()]}";
    stack<char> st;

    for(char c : s) {
        if(c=='('||c=='{'||c=='[')
            st.push(c);
        else {
            if(st.empty()) return 0;
            st.pop();
        }
    }

    if(st.empty())
        cout << "Balanced";
    else
        cout << "Not Balanced";
}
