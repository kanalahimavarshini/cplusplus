#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node* head = new Node{1, NULL};
    head->next = new Node{2, NULL};

    Node *prev = NULL, *curr = head, *next;

    while(curr != NULL) {
        next = curr->next;
        curr->next = prev;
        prev = curr;
        curr = next;
    }

    while(prev != NULL) {
        cout << prev->data << " ";
        prev = prev->next;
    }
}
#include <iostream>
using namespace std;

int search(int arr[], int n, int key) {
    for(int i = 0; i < n; i++) {
        if(arr[i] == key)
            return i;
    }
    return -1;
}

int main() {
    int arr[] = {1,2,3,4};
    cout << search(arr, 4, 3);
}
#include <iostream>
using namespace std;

int binarySearch(int arr[], int n, int key) {
    int low = 0, high = n-1;

    while(low <= high) {
        int mid = (low + high) / 2;

        if(arr[mid] == key) return mid;
        else if(arr[mid] < key) low = mid + 1;
        else high = mid - 1;
    }
    return -1;
}

int main() {
    int arr[] = {1,2,3,4,5};
    cout << binarySearch(arr, 5, 4);
}
