void toh(int n, char from, char to, char aux) {
    if(n == 1) {
        cout << "Move disk 1 from " << from << " to " << to << endl;
        return;
    }
    toh(n-1, from, aux, to);
    cout << "Move disk " << n << " from " << from << " to " << to << endl;
    toh(n-1, aux, to, from);
}

int main() {
    toh(3, 'A', 'C', 'B');
}
