#include <iostream>
using namespace std;

int main() {
    int arr[] = {2,7,11,15};
    int target = 9;

    for(int i = 0; i < 4; i++) {
        for(int j = i+1; j < 4; j++) {
            if(arr[i] + arr[j] == target) {
                cout << arr[i] << " " << arr[j];
            }
        }
    }
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {2,2,1,2,3};
    int n = 5;

    for(int i = 0; i < n; i++) {
        int count = 0;

        for(int j = 0; j < n; j++) {
            if(arr[i] == arr[j])
                count++;
        }

        if(count > n/2) {
            cout << "Majority: " << arr[i];
            break;
        }
    }
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {1,2,3,4,5};
    int n = 5, k = 2;

    k = k % n;

    for(int i = 0; i < k; i++) {
        int last = arr[n-1];

        for(int j = n-1; j > 0; j--)
            arr[j] = arr[j-1];

        arr[0] = last;
    }

    for(int i = 0; i < n; i++)
        cout << arr[i] << " ";
}
#include <iostream>
using namespace std;

int main() {
    int a[] = {1,2,3};
    int b[] = {1,2,3};

    bool equal = true;

    for(int i = 0; i < 3; i++) {
        if(a[i] != b[i]) {
            equal = false;
            break;
        }
    }

    if(equal)
        cout << "Equal";
    else
        cout << "Not Equal";
}