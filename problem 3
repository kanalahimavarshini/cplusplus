#include <iostream>
using namespace std;

int main() {
    string arr[] = {"flower","flow","flight"};
    string prefix = arr[0];

    for(int i = 1; i < 3; i++) {
        while(arr[i].find(prefix) != 0) {
            prefix = prefix.substr(0, prefix.length()-1);
        }
    }

    cout << prefix;
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {1,1,2,2,3};
    int n = 5, j = 0;

    for(int i = 1; i < n; i++) {
        if(arr[i] != arr[j]) {
            arr[++j] = arr[i];
        }
    }

    for(int i = 0; i <= j; i++)
        cout << arr[i] << " ";
}