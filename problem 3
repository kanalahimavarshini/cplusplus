#include <iostream>
using namespace std;

int main() {
    int arr[][2] = {{1,3},{2,6},{8,10}};
    int n = 3;

    int start = arr[0][0], end = arr[0][1];

    for(int i = 1; i < n; i++) {
        if(arr[i][0] <= end) {
            end = max(end, arr[i][1]);
        } else {
            cout << start << " " << end << endl;
            start = arr[i][0];
            end = arr[i][1];
        }
    }

    cout << start << " " << end;
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {3,0,2,0,4};
    int n = 5, water = 0;

    for(int i = 1; i < n-1; i++) {
        int left = arr[i], right = arr[i];

        for(int j = 0; j < i; j++)
            left = max(left, arr[j]);

        for(int j = i+1; j < n; j++)
            right = max(right, arr[j]);

        water += min(left, right) - arr[i];
    }

    cout << "Water: " << water;
}
