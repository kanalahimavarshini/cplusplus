#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* left;
    Node* right;
};

int sumNodes(Node* root) {
    if(root == NULL) return 0;
    return root->data + sumNodes(root->left) + sumNodes(root->right);
}

int main() {
    Node* root = new Node{1, NULL, NULL};
    root->left = new Node{2, NULL, NULL};

    cout << sumNodes(root);
}