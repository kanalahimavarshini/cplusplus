#include <iostream>
using namespace std;

int main() {
    int arr[] = {1, 2, 3, 4, 5};
    int key = 4, low = 0, high = 4;

    while(low <= high) {
        int mid = (low + high) / 2;

        if(arr[mid] == key) {
            cout << "Found";
            break;
        }
        else if(arr[mid] < key)
            low = mid + 1;
        else
            high = mid - 1;
    }
}
#include <iostream>
using namespace std;

int main() {
    int arr[] = {5, 3, 2, 4};

    for(int i = 0; i < 4; i++) {
        for(int j = 0; j < 3; j++) {
            if(arr[j] > arr[j+1]) {
                swap(arr[j], arr[j+1]);
            }
        }
    }

    for(int i = 0; i < 4; i++)
        cout << arr[i] << " ";
}