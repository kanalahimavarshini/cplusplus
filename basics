int main() {
    int n = 121, temp, rev = 0;
    temp = n;

    while(n != 0) {
        rev = rev * 10 + n % 10;
        n /= 10;
    }

    if(temp == rev)
        cout << "Palindrome";
    else
        cout << "Not Palindrome";
}
